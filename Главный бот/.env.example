# Токен вашего Telegram-бота (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Telegram ID администратора (вашего аккаунта, например: 5690724590)
ADMIN_ID=your_telegram_id_here

# Юзернейм или ID канала для проверки подписки (Бот должен быть назначен администратором канала!)
CHANNEL_ID=@your_channel_username

# Публичная ссылка на канал для отправки пользователям
CHANNEL_LINK=https://t.me/your_channel_username
