function createForm() {
  // Создаем новую Google Форму с заголовком
  var form = FormApp.create('Входной опрос для опытных агентов (Точка А)');
  form.setDescription('Этот опрос создан для оцифровки твоей текущей ситуации перед стартом обучения. Здесь нет «правильных» или «неправильных» ответов. Цель — честно посмотреть на свои цифры, методы работы и отношение к рынку 2026 года, чтобы адаптировать обучение под твой личный результат и кошелек.');
  
  // ==========================================
  // Блок 1. Личные данные и контакты
  // ==========================================
  var section1 = form.addPageBreakItem()
    .setTitle('Блок 1. Личные данные и контакты')
    .setHelpText('Цель: собрать контактные данные участников для связи и анализа их медийного присутствия.');
  
  form.addTextItem()
    .setTitle('1. Твое ФИО (Фамилия, Имя, Отчество)')
    .setRequired(true);
  
  form.addTextItem()
    .setTitle('2. Номер телефона (привязанный к Telegram/WhatsApp)')
    .setRequired(true);
  
  form.addTextItem()
    .setTitle('3. Ссылка на твой Instagram и/или Telegram-канал')
    .setRequired(true);
  
  var q4 = form.addCheckboxItem()
    .setTitle('4. Какие социальные сети ты сейчас ведешь и развиваешь для привлечения клиентов?');
  q4.setChoices([
    q4.createChoice('Instagram (запрещен на территории РФ)'),
    q4.createChoice('Telegram (канал/блог)'),
    q4.createChoice('VK (ВКонтакте)'),
    q4.createChoice('YouTube / Shorts / Reels'),
    q4.createChoice('Никакие не веду, клиенты приходят иначе')
  ]);
  q4.showOtherOption(true);

  // ==========================================
  // Блок 2. Источники клиентов и лидогенерация
  // ==========================================
  form.addPageBreakItem()
    .setTitle('Блок 2. Источники клиентов и лидогенерация')
    .setHelpText('Цель: определить, из каких каналов приходят клиенты и какие инструменты привлечения используются на старте.');
  
  var q5 = form.addCheckboxItem()
    .setTitle('5. Откуда к тебе сейчас приходят клиенты? (Выбери все подходящие варианты)');
  q5.setChoices([
    q5.createChoice('Сарафанное радио (рекомендации прошлых клиентов, знакомых)'),
    q5.createChoice('Личные социальные сети (Instagram, Telegram, VK)'),
    q5.createChoice('Рассылки (в мессенджерах, соцсетях, email-рассылки)'),
    q5.createChoice('Покупка платной рекламы (таргет, контекст, реклама у блогеров)'),
    q5.createChoice('Клиенты от агентства / входящий трафик компании'),
    q5.createChoice('Холодные звонки / базы данных')
  ]);
  q5.showOtherOption(true);
  
  form.addParagraphTextItem()
    .setTitle('6. Какие инструменты привлечения ты пробовал(а) за последнее время, но они не принесли желаемого результата? Почему, по твоему мнению, они не сработали?');

  // ==========================================
  // Блок 3. Твоя Точка А в цифрах (Оцифровка реальности)
  // ==========================================
  form.addPageBreakItem()
    .setTitle('Блок 3. Твоя Точка А в цифрах (Оцифровка реальности)')
    .setHelpText('Цель: убрать иллюзии и зафиксировать твердые стартовые показатели.');
  
  var q7 = form.addMultipleChoiceItem()
    .setTitle('7. Каков твой средний личный доход (чистыми) в месяц за последние 3 месяца?');
  q7.setChoices([
    q7.createChoice('До 100 000 руб.'),
    q7.createChoice('100 000 — 150 000 руб.'),
    q7.createChoice('150 000 — 250 000 руб.'),
    q7.createChoice('250 000 — 400 000 руб.'),
    q7.createChoice('Более 400 000 руб.')
  ]);
  
  var q8 = form.addMultipleChoiceItem()
    .setTitle('8. Какое соотношение сделок в твоем портфеле за последний квартал?');
  q8.setChoices([
    q8.createChoice('Только новостройки (первичка)'),
    q8.createChoice('В основном новостройки, иногда вторичка'),
    q8.createChoice('50 / 50 (и первичка, и вторичка в равной степени)'),
    q8.createChoice('В основном вторичка, иногда новостройки'),
    q8.createChoice('Только вторичка')
  ]);
  
  form.addTextItem()
    .setTitle('9. Сколько сделок по новостройкам ты закрыл(а) за последние 30 дней?');
  
  form.addTextItem()
    .setTitle('10. Каков твой средний чек комиссии с одной сделки по новостройке за последнее время?');
  
  form.addParagraphTextItem()
    .setTitle('11. Давай оцифруем твою воронку. Из 10 клиентов, которые обратились к тебе за последний месяц с запросом на покупку недвижимости:')
    .setHelpText('Подсказка для заполнения: Сколько из них согласились на встречу (офлайн/Zoom)? Сколько ушли «думать» после того, как ты скинул(а) им варианты? Сколько купили сами у застройщика или через других? Сколько реально дошли до сделки с тобой?');

  // ==========================================
  // Блок 4. Рынок 2026 и твои убеждения (Болезни Агента-Рыбака)
  // ==========================================
  form.addPageBreakItem()
    .setTitle('Блок 4. Рынок 2026 и твои убеждения (Болезни Агента-Рыбака)')
    .setHelpText('Цель: выявить психологические проекции страхов на клиентов и определить текущий стиль ведения переговоров.');
  
  form.addParagraphTextItem()
    .setTitle('12. Честно: если бы ты прямо сейчас покупал(а) квартиру для своей семьи в Уфе, какую финансовую схему ты бы выбрал(а) лично для себя?')
    .setHelpText('Подсказка: Опиши схему (рассрочка, транши, субсидия, стандартная ипотека) и почему именно она.');
  
  var q13 = form.addMultipleChoiceItem()
    .setTitle('13. Когда клиент говорит: «Ипотека под 18% или удорожание цены на 1.5 млн ради ставки 6% — это грабеж застройщиков, я не буду переплачивать ни за что». Какова твоя первая внутренняя реакция?');
  q13.setChoices([
    q13.createChoice('Соглашаюсь с ним внутри — это действительно грабеж и несправедливость, мне тяжело это продавать.'),
    q13.createChoice('Пытаюсь объяснить, что деваться некуда, программы закроют и завтра будет еще хуже (работаю через FOMO/давление).'),
    q13.createChoice('Спокойно принимаю его эмоцию, а затем раскладываю на калькуляторе математику переплаты по процентам за 5-10 лет, сравнивая варианты с удорожанием и без него (перевожу в цифры).')
  ]);
  q13.showOtherOption(true);
  
  form.addParagraphTextItem()
    .setTitle('14. Как ты реагируешь, когда клиент заявляет: «У меня есть 4 млн рублей. Я положу их на депозит под 20% годовых, заработаю за год 800 тысяч, а потом куплю без кредитов»? Что ты ему обычно отвечаешь?')
    .setHelpText('Подсказка: Опиши свой реальный аргумент, который ты используешь в таком диалоге.');
  
  form.addParagraphTextItem()
    .setTitle('15. Считаешь ли ты, что твой опыт (5-10+ лет на рынке) дает тебе право решать за клиента, какой ЖК ему подходит, а какой нет? Как ты доносишь свое мнение, если клиент влюблен в «плохой» объект?');
  
  form.addParagraphTextItem()
    .setTitle('16. Бывали ли у тебя за последние 3 месяца ситуации, когда сделка по новостройке срывалась перед самым подписанием ДДУ? В чем, по твоему мнению, была реальная причина срыва?');

  // ==========================================
  // Блок 5. Твоя работа с клиентом
  // ==========================================
  form.addPageBreakItem()
    .setTitle('Блок 5. Твоя работа с клиентом')
    .setHelpText('Цель: проверить глубину квалификации клиента и методы ведения сделки.');
  
  var q17 = form.addMultipleChoiceItem()
    .setTitle('17. В какой момент ты обычно отправляешь клиенту первые подборки планировок и презентации ЖК?');
  q17.setChoices([
    q17.createChoice('Сразу после первого контакта, как только клиент спросил «А что у вас есть по Дёме/Центру?».'),
    q17.createChoice('После короткого опроса (бюджет, количество комнат, район).'),
    q17.createChoice('Только после проведения полного финансового аудита (ПВ, лимиты, комфортный платеж) и понимания истинной задачи покупки.')
  ]);
  
  form.addParagraphTextItem()
    .setTitle('18. Представь кейс: Семья с ребенком 2 лет хочет «купить какую-нибудь двушку до 7 млн поближе к центру». Какие 3 первых вопроса ты им задашь при знакомстве?')
    .setHelpText('Подсказка: Напиши конкретные формулировки вопросов.');
  
  form.addParagraphTextItem()
    .setTitle('19. Как ты считаешь, что на самом деле покупает инвестор, который приходит с запросом: «У меня свободные 5 млн рублей, хочу выгодно вложить в недвижимость»?')
    .setHelpText('Подсказка: В чем его истинная жизненная потребность/страх на твой взгляд?');
  
  form.addParagraphTextItem()
    .setTitle('20. Как ты действуешь, когда менеджер отдела продаж застройщика при клиенте начинает давить: «У нас остался один лот на этом этаже, бронируйте за 50 000 рублей прямо сейчас, иначе он уйдет»?')
    .setHelpText('Подсказка: Как ты защищаешь интересы клиента в этот момент?');

  // ==========================================
  // Блок 6. Самообучение, регламенты и самодисциплина
  // ==========================================
  form.addPageBreakItem()
    .setTitle('Блок 6. Самообучение, регламенты и самодисциплина')
    .setHelpText('Цель: прояснить правила игры на обучении и готовность к регулярной работе.');
  
  var q21 = form.addMultipleChoiceItem()
    .setTitle('21. Это обучение построено на самообучении с обязательными тестами на знание регламентов/продуктов и практическими заданиями (например, записать ГС с отработкой возражения, сдать заполненный дашборд). Как ты к этому относишься?');
  q21.setChoices([
    q21.createChoice('Полностью готов(а). Понимаю, что без тестов и практики обучение не сработает.'),
    q21.createChoice('Готов(а) изучать материалы, но считаю, что тесты и запись голосовых — это для новичков. Мне это не подходит.'),
    q21.createChoice('Буду смотреть лекции, но выполнять домашние задания и записывать ГС мне некомфортно/некогда.')
  ]);
  
  var q22 = form.addMultipleChoiceItem()
    .setTitle('22. Сколько чистого времени в неделю ты готов(а) инвестировать в изучение материалов и отработку переговорных навыков на этом курсе?');
  q22.setChoices([
    q22.createChoice('До 2 часов в неделю (в фоновом режиме)'),
    q22.createChoice('3–5 часов в неделю (готов(а) выделять фиксированные тайм-блоки)'),
    q22.createChoice('Более 5 часов в неделю (максимальное погружение)')
  ]);
  
  var q23 = form.addMultipleChoiceItem()
    .setTitle('23. Ведешь ли ты сейчас ежедневный учет своих действий (дашборд: сколько сделал(а) рассылок по базе, сколько начал(а) новых диалогов, сколько встреч назначил(а) и провел(а))?');
  q23.setChoices([
    q23.createChoice('Да, веду CRM или личную таблицу каждый день.'),
    q23.createChoice('Веду частично, фиксирую только ключевые вехи (встречи/брони) в блокноте.'),
    q23.createChoice('Не веду, держу все в голове, действую по ситуации.')
  ]);
  
  form.addParagraphTextItem()
    .setTitle('24. Насколько строго ты контролируешь регламенты фиксации уникальности клиентов у застройщиков? Терял(а) ли ты комиссию за последние полгода из-за «пересечения баз»?');

  // ==========================================
  // Блок 7. Рефлексия, ожидания и Точка Б
  // ==========================================
  form.addPageBreakItem()
    .setTitle('Блок 7. Рефлексия, ожидания и Точка Б')
    .setHelpText('Цель: снять текущие переживания и заключить внутренний контракт на результат.');
  
  form.addParagraphTextItem()
    .setTitle('25. Что сейчас вызывает у тебя наибольшее беспокойство или эмоциональный спад в работе?')
    .setHelpText('Подсказка: Отсутствие заявок, высокие ставки ипотеки, регламенты застройщиков, капризные клиенты, выгорание или что-то другое? Напиши честно.');
  
  form.addTextItem()
    .setTitle('26. Какой стабильный чистый доход в месяц ты хочешь получать через 3 месяца после завершения обучения?');
  
  form.addParagraphTextItem()
    .setTitle('27. Что для тебя лично будет главным критерием того, что это обучение прошло успешно?')
    .setHelpText('Подсказка: Рост дохода в X раз, систематизация рабочего дня, появление скриптов и калькуляторов, уверенность при звонках и т.д.');
  
  form.addParagraphTextItem()
    .setTitle('28. Есть ли у тебя сейчас скепсис или внутреннее сопротивление перед стартом этого обучения? Если да, напиши честно — что смущает или вызывает сомнения?')
    .setHelpText('Подсказка: Это самый важный вопрос. Честный ответ поможет сделать обучение полезным именно для тебя.');

  var editUrl = form.getEditUrl();
  var pubUrl = form.getPublishedUrl();
  
  Logger.log('=== УСПЕШНО СОЗДАНО ===');
  Logger.log('Ссылка для редактирования: ' + editUrl);
  Logger.log('Ссылка для заполнения: ' + pubUrl);
}
